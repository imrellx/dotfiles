# Theme indirection managed by set_theme; don't re-bake palette inline.
# Diverges from ivn-term/config/ghostty/config, which ships an inline palette.

font-family = BlexMono Nerd Font
font-size = 11
font-feature = -calt, -liga, -dlig

cursor-style-blink = false
cursor-text = #000000

window-padding-x = 4
window-padding-y = 2
window-padding-balance = true

# Left Option = Alt on macOS so tmux M-* binds fire; right Option stays native
# for special characters. No-op on Linux (macos-* keys are silently ignored).
macos-option-as-alt = left

# Load theme.
config-file = ?theme

# Load a custom config for overrides, ? silently fails if the file is missing.
config-file = ?config.local
