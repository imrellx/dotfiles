# shellcheck shell=bash

# Detect current shell
if [ -n "$BASH_VERSION" ]; then
  _shell="bash"
elif [ -n "$ZSH_VERSION" ]; then
  _shell="zsh"
fi

# Starship prompt
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init "$_shell")"
fi

# Zoxide (sesh frecent-dirs source)
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init "$_shell")"
fi

# mise (runtime manager)
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate "$_shell")"
fi

# Zsh-only plugins (compinit already ran in .zoptions)
if [ "$_shell" = "zsh" ]; then
  # 1. zsh-vi-mode first so zvm_after_init_commands exists for the bindings below.
  # shellcheck disable=SC1091
  [ -f "${XDG_DATA_HOME}/zsh-vi-mode/zsh-vi-mode.plugin.zsh" ] \
    && . "${XDG_DATA_HOME}/zsh-vi-mode/zsh-vi-mode.plugin.zsh"

  # 2. fzf keybindings + history-search binds must land after vi-mode init,
  #    otherwise vi-mode wipes them.
  zvm_after_init_commands+=(
    ". <(fzf --zsh)"
    "bindkey '^p' history-search-backward"
    "bindkey '^n' history-search-forward"
    "bindkey '^[OA' history-search-backward"
    "bindkey '^[OB' history-search-forward"
    "bindkey '^[[A' history-search-backward"
    "bindkey '^[[B' history-search-forward"
  )

  # 3. zsh-autosuggestions
  # shellcheck disable=SC1091
  [ -f "${XDG_DATA_HOME}/zsh-autosuggestions/zsh-autosuggestions.zsh" ] \
    && . "${XDG_DATA_HOME}/zsh-autosuggestions/zsh-autosuggestions.zsh"

  # 4. fast-syntax-highlighting must wrap zle last.
  # shellcheck disable=SC1091
  [ -f "${XDG_DATA_HOME}/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ] \
    && . "${XDG_DATA_HOME}/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
fi

unset _shell
