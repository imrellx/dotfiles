#!/usr/bin/env bash
# Customize these in the config file instead of editing them here.

# shellcheck disable=SC2034
declare -A DEFAULT_MISE_LANGUAGES

# Language runtimes. Node pinned to @22 because npm tooling regularly breaks
# on major bumps; the rest float on latest. Python intentionally omitted —
# uv-first Python posture (see CLAUDE.md), and on Linux a mise-managed
# python shadows /usr/bin/python via PATH and breaks AUR build scripts.
# Add per-machine via MISE_LANGUAGES_EXTRAS if you need it.
DEFAULT_MISE_LANGUAGES["node"]="node@22"
DEFAULT_MISE_LANGUAGES["bun"]="bun@latest"
DEFAULT_MISE_LANGUAGES["rust"]="rust@latest"
DEFAULT_MISE_LANGUAGES["go"]="go@latest"
DEFAULT_MISE_LANGUAGES["zig"]="zig@latest"

# Non-language CLI tools installed via mise's npm backend reuse this array;
# the install loop checks ${XDG_DATA_HOME}/mise/shims/${key} for idempotency.
DEFAULT_MISE_LANGUAGES["pi"]="npm:@mariozechner/pi-coding-agent@latest"
