#!/usr/bin/env bash
# lifted from omarchy/bin/omarchy-battery-remaining-time

# Returns the battery time remaining (to empty or full) in a compact format.

battery_info=$(upower -i "$(upower -e | grep BAT | head -n1)")

echo "$battery_info" | awk '/time to (empty|full)/ {
    value = $4
    unit = $5
    if (unit ~ /^minute/) {
        printf "%dm", int(value)
    } else {
        hours = int(value)
        minutes = int((value - hours) * 60)
        if (minutes > 0) {
            printf "%dh %dm", hours, minutes
        } else {
            printf "%dh", hours
        }
    }
    exit
}'
